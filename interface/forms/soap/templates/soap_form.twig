                let details = medication.content || '';
                try {
                    const escapedHeader = headerText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                    const headerRegex = new RegExp('^\\s*' + escapedHeader + '\\s*[:\\-–—]?\\s*', 'i');
                    details = details.replace(headerRegex, '').trim();
                } catch (e) {
                    console.warn('Medication header stripping failed', e);
                }

                const contentToShow = details || medication.content || '';
                const combinedLine = contentToShow ? (headerText + ' - ' + contentToShow) : headerText;
                const draggableItem = createDraggableItem(medication.type, combinedLine, '');
                container.appendChild(draggableItem);
            });
        }
        
        function populateProblems(problems) {
            const container = document.getElementById('problems-container');
            const loading = document.getElementById('problems-loading');
            
            if (!container) {
                console.warn('Problems container not found');
                return;
            }
            
            if (loading) {
                loading.style.display = 'none';
            }
            
            container.innerHTML = '';
            
            if (problems.length === 0) {
                container.innerHTML = '<div class="text-muted">{{ "No active medical problems"|xlt }}</div>';
                return;
            }
            
            problems.forEach(problem => {
                const item = createDraggableItem(problem.type, problem.header, problem.content);
                container.appendChild(item);
            });
            
            // Initialize drag and drop for new items
            initializeDragAndDrop();
        }
        
        function populateProblemsTab(problems) {
            console.log('PopulateProblemsTab called with:', problems);
            const container = document.getElementById('problems-container');
            const loading = document.getElementById('problems-loading');
            
            if (!container) {
                console.warn('Problems container not found');
                return;
            }
            
            if (loading) {
                loading.style.display = 'none';
            }
            
            container.innerHTML = '';
            
            if (problems.length === 0) {
                container.innerHTML = '<div class="text-muted">{{ "No medical problems documented"|xlt }}</div>';
                return;
            }
            
            problems.forEach(problem => {
                const draggableItem = createDraggableItem(problem.type, problem.header, problem.content);
                container.appendChild(draggableItem);
            });
        }

        function populateOrdersReferralsTab(forms) {
            console.log('PopulateOrdersReferralsTab called with:', forms);
            const container = document.getElementById('orders-referrals-container');
            const loading = document.getElementById('orders-referrals-loading');
            
            if (!container) {
                console.warn('Orders & Referrals container not found');
                return;
            }
            
            if (loading) {
                loading.style.display = 'none';
            }
            
            container.innerHTML = '';
            
            if (!forms || forms.length === 0) {
                container.innerHTML = '<div class="text-muted">{{ "No orders or referrals documented"|xlt }}</div>';
                return;
            }
            
            // Show all forms returned by the API (they are already filtered to Orders category)
            forms.forEach(form => {
                if (form.type === 'LBF') {
                    let item = createDraggableItem('order-referral', form.header, form.content);
                    container.appendChild(item);
                }
            });
            
            // Initialize drag and drop for the newly added items
            initializeDragAndDrop();
        }

        // Add global functions to window for onclick handlers
        window.toggleSection = toggleSection;

        // Initialize sidebar - open patient details by default
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-open patient details section
            toggleSection('patient-details');
        });

        $('#btnClose').click(close);
    </script>
</body>
</html>
