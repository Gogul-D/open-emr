
<html>
<head>
<title>{{ 'SOAP'|xlt }}</title>
    {{ setupHeader() }}
    <script>
        // Define template management functions immediately
        const templateFunctions = {
            // Load template contexts when section is opened
            loadTemplateContexts: function() {
                return new Promise((resolve, reject) => {
                    const csrfToken = {{ csrfTokenRaw()|json_encode }};
                    console.log('Loading contexts...');
                    fetch('../../forms/soap/get_template_data.php?csrf_token_form=' + encodeURIComponent(csrfToken))
                        .then(response => response.json())
                        .then(data => {
                            console.log('Template data response:', data);
                            if (data.success && data.contexts) {
                                const contextSelect = document.getElementById('filterContext');
                                contextSelect.innerHTML = '<option value="">{{ "Select Context"|xlt }}</option>';
                                data.contexts.forEach(context => {
                                    console.log('Adding context:', context);
                                    contextSelect.innerHTML += `<option value="${context}">${context}</option>`;
                                });
                                
                                // Also populate browse context dropdown
                                const browseContextSelect = document.getElementById('browseContext');
                                if (browseContextSelect) {
                                    browseContextSelect.innerHTML = '<option value="">All Contexts</option>';
                                    data.contexts.forEach(context => {
                                        browseContextSelect.innerHTML += `<option value="${context}">${context}</option>`;
                                    });
                                }
                                
                                // Populate create context datalist
                                const createContextDatalist = document.getElementById('contextList');
                                if (createContextDatalist) {
                                    createContextDatalist.innerHTML = '';
                                    data.contexts.forEach(context => {
                                        createContextDatalist.innerHTML += `<option value="${context}">`;
                                    });
                                }
                                
                                console.log('Contexts loaded:', data.contexts.length);
                                
                                // Load categories for the currently selected context
                                const selectedContext = browseContextSelect.value;
                                if (selectedContext) {
                                    templateFunctions.loadBrowseCategories(selectedContext);
                                }
                                
                                resolve(data.contexts);
                            } else {
                                console.warn('No contexts found or error:', data);
                                if (data.debug) {
                                    console.log('Debug info:', data.debug);
                                }
                                reject(new Error('No contexts found or error'));
                            }
                        })
                        .catch(error => {
                            console.error('Error loading contexts:', error);
                            const container = document.getElementById('templates-container');
                            container.innerHTML = '<div class="alert alert-danger">Error loading templates. Check console for details.</div>';
                            reject(error);
                        });
                });
            },

            // Load browse categories
            loadBrowseCategories: function(context = '') {
                return new Promise((resolve, reject) => {
                    if (!context) {
                        // Clear category dropdown when no context selected
                        const browseCategorySelect = document.getElementById('browseCategory');
                        if (browseCategorySelect) {
                            browseCategorySelect.innerHTML = '<option value="">All Categories</option>';
                            browseCategorySelect.value = '';
                        }
                        const createCategoryDatalist = document.getElementById('categoryList');
                        if (createCategoryDatalist) {
                            createCategoryDatalist.innerHTML = '';
                        }
                        resolve([]);
                        return;
                    }
                    
                    const csrfToken = {{ csrfTokenRaw()|json_encode }};
                    const url = '../../forms/soap/get_template_data.php?action=get_categories&context=' + encodeURIComponent(context) + '&csrf_token_form=' + encodeURIComponent(csrfToken);
                    
                    fetch(url)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success && data.categories) {
                                // Update browse category dropdown
                                const browseCategorySelect = document.getElementById('browseCategory');
                                if (browseCategorySelect) {
                                    browseCategorySelect.innerHTML = '<option value="">All Categories</option>';
                                    data.categories.forEach(category => {
                                        browseCategorySelect.innerHTML += `<option value="${category}">${category}</option>`;
                                    });
                                    browseCategorySelect.value = '';
                                }
                                
                                // Update create category datalist
                                const createCategoryDatalist = document.getElementById('categoryList');
                                if (createCategoryDatalist) {
                                    createCategoryDatalist.innerHTML = '';
                                    data.categories.forEach(category => {
                                        createCategoryDatalist.innerHTML += `<option value="${category}">`;
                                    });
                                }
                                
                                resolve(data.categories);
                            } else {
                                reject(new Error('No categories found or error'));
                            }
                        })
                        .catch(error => {
                            console.error('Error loading categories:', error);
                            reject(error);
                        });
                });
            },

            // Load browse templates
            loadBrowseTemplates: function(context = '', category = '') {
                return new Promise((resolve, reject) => {
                    const csrfToken = {{ csrfTokenRaw()|json_encode }};
                    const url = '../../forms/soap/get_template_data.php?action=get_templates&context=' + encodeURIComponent(context) + '&category=' + encodeURIComponent(category) + '&csrf_token_form=' + encodeURIComponent(csrfToken);
                    
                    console.log('Loading templates with URL:', url);
                    
                    fetch(url)
                        .then(response => response.json())
                        .then(data => {
                                if (data.success && data.templates) {
                                    const templateList = document.getElementById('templateList');
                                    if (templateList) {
                                        templateList.innerHTML = '';
                                        
                                        if (data.templates.length === 0) {
                                            templateList.innerHTML = '<li class="list-group-item text-muted">No templates found</li>';
                                            resolve([]);
                                            return;
                                        }
                                        
                                        data.templates.forEach(template => {
                                            const deleteBtn = template.can_delete ? 
                                                `<button class="btn btn-sm btn-outline-danger ms-2" onclick="deleteTemplate(${template.id})" title="Delete Template">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>` : '';
                                                
                                            templateList.innerHTML += `
                                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                                    <div class="flex-grow-1 me-3" style="min-width: 0;">
                                                        <strong style="word-break: break-word;">${template.name}</strong>
                                                        <br><small class="text-muted">${template.context} - ${template.category}</small>
                                                    </div>
                                                    <div class="flex-shrink-0 d-flex gap-2">
                                                        <button class="btn btn-sm btn-info" onclick="viewTemplate(${template.id})">
                                                            <i class="fas fa-eye"></i> View
                                                        </button>
                                                        ${deleteBtn}
                                                    </div>
                                                </li>
                                            `;
                                        });
                                    }
                                    
                                    resolve(data.templates);
                                } else {
                                    reject(new Error('No templates found or error'));
                                }
                            })
                            .catch(error => {
                                console.error('Error loading templates:', error);
                                reject(error);
                            });
                });
            },

            // Load templates section
            loadTemplatesSection: function() {
                console.log('Loading templates section...');
                const templatesSection = document.getElementById('templates');
                const header = document.querySelector('.section-header[onclick="window.handleTemplatesSectionClick()"]');
                const parentSection = header.closest('.clinical-section');
                
                if (templatesSection.classList.contains('active')) {
                    templatesSection.classList.remove('active');
                    header.classList.remove('active');
                    parentSection.classList.add('collapsed');
                } else {
                    templatesSection.classList.add('active');
                    header.classList.remove('active');
                    parentSection.classList.remove('collapsed');
                    this.loadTemplateContexts();
                }
            },

            // Load categories for selected context
            loadTemplateCategories: function() {
                const context = document.getElementById('filterContext').value;
                console.log('Loading categories for context:', context);
                
                if (!context) {
                    document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                    document.getElementById('templates-container').innerHTML = '';
                    return Promise.resolve();
                }

                return new Promise((resolve, reject) => {
                    const csrfToken = {{ csrfTokenRaw()|json_encode }};
                    fetch(`../../forms/soap/get_template_data.php?csrf_token_form=${encodeURIComponent(csrfToken)}&context=${encodeURIComponent(context)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success && data.categories) {
                                const categorySelect = document.getElementById('filterCategory');
                                categorySelect.innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                                data.categories.forEach(category => {
                                    categorySelect.innerHTML += `<option value="${category}">${category}</option>`;
                                });
                                resolve(data.categories);
                            } else {
                                reject(new Error('No categories found or error'));
                            }
                        })
                        .catch(error => {
                            console.error('Error loading categories:', error);
                            reject(error);
                        });
                });
            },

            // Load templates list
            loadTemplatesList: function() {
                const context = document.getElementById('filterContext').value;
                const category = document.getElementById('filterCategory').value;
                
                if (!context || !category) {
                    document.getElementById('templates-container').innerHTML = '';
                    return Promise.resolve();
                }

                const csrfToken = {{ csrfTokenRaw()|json_encode }};
                return fetch(`../../forms/soap/get_template_data.php?csrf_token_form=${encodeURIComponent(csrfToken)}&context=${encodeURIComponent(context)}&category=${encodeURIComponent(category)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.templates) {
                            const container = document.getElementById('templates-container');
                            container.innerHTML = '';
                            data.templates.forEach(template => {
                                const item = createDraggableItem('template', template.template_name, template.template_content);
                                container.appendChild(item);
                            });
                            initializeDragAndDrop();
                        }
                    })
                    .catch(error => console.error('Error loading templates:', error));
            }
        };

        // Make functions globally available and properly bound
        // Make all template functions globally available
        window.templateFunctions = templateFunctions;
        
        window.handleTemplatesSectionClick = function() {
            templateFunctions.loadTemplatesSection.call(templateFunctions);
        };

        window.loadTemplateCategories = function() {
            return templateFunctions.loadTemplateCategories();
        };

        window.loadTemplatesList = function() {
            return templateFunctions.loadTemplatesList();
        };

        window.loadTemplateContexts = function() {
            return templateFunctions.loadTemplateContexts();
        };
        window.selectTemplate = function(templateId) {
            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            fetch(`../../forms/soap/get_template_data.php?action=get_template&id=${templateId}&csrf_token_form=${encodeURIComponent(csrfToken)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.template) {
                        // Create draggable item from template
                        const item = createDraggableItem('template', data.template.name, data.template.content);
                        
                        // Add to SOAP note (you may need to adjust this based on your drag-and-drop implementation)
                        const soapNote = document.getElementById('soap_note');
                        if (soapNote) {
                            soapNote.value += (soapNote.value ? '\n\n' : '') + data.template.content;
                        }
                        
                        // Close modal
                        $('#templateModal').modal('hide');
                        
                        // Show success message
                        alert('Template added to SOAP note successfully!');
                    } else {
                        alert('Error loading template: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error selecting template:', error);
                    alert('Error selecting template');
                });
        };

        window.viewTemplate = function(templateId) {
            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            fetch(`../../forms/soap/get_template_data.php?action=get_template&id=${templateId}&csrf_token_form=${encodeURIComponent(csrfToken)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.template) {
                        // Show template content in a modal
                        showTemplateContentModal(data.template);
                    } else {
                        alert('Error loading template: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error viewing template:', error);
                    alert('Error loading template');
                });
        };

        window.showTemplateContentModal = function(template) {
            // Create a simple modal to show template content
            const modalHtml = `
                <div class="modal fade" id="viewTemplateModal" tabindex="-1" role="dialog">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">${template.name}</h5>
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-2">
                                    <strong>Context:</strong> ${template.context}<br>
                                    <strong>Category:</strong> ${template.category}
                                </div>
                                <hr>
                                <div class="template-content" style="white-space: pre-wrap; font-family: monospace; background: #f8f9fa; padding: 10px; border-radius: 4px;">
                                    ${template.content}
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            // Remove existing modal if present
            $('#viewTemplateModal').remove();

            // Add modal to body
            $('body').append(modalHtml);

            // Show modal
            $('#viewTemplateModal').modal('show');

            // Clean up modal when hidden
            $('#viewTemplateModal').on('hidden.bs.modal', function() {
                // Reset filter dropdowns
                document.getElementById('filterContext').value = '';
                document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                // Clear templates container
                document.getElementById('templates-container').innerHTML = '';
                // Reset browse selects
                document.getElementById('browseContext').value = '';
                templateFunctions.loadBrowseCategories('');
                templateFunctions.loadBrowseTemplates('', '');
                // Reset create inputs
                const templateContext = document.getElementById('templateContext');
                if (templateContext) templateContext.value = '';
                const templateCategory = document.getElementById('templateCategory');
                if (templateCategory) templateCategory.value = '';
                // Clear template list
                document.getElementById('templateList').innerHTML = '<li class="list-group-item text-muted">Select a context and category to view templates</li>';
                $(this).remove();
            });
        };

        window.deleteTemplate = function(templateId) {
            if (!confirm('Are you sure you want to delete this template? This action cannot be undone.')) {
                return;
            }
            
            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            fetch('../../forms/soap/manage_templates.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `action=delete_template&template_id=${templateId}&csrf_token_form=${encodeURIComponent(csrfToken)}`
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Reload templates list
                        const context = document.getElementById('browseContext').value;
                        const category = document.getElementById('browseCategory').value;
                        templateFunctions.loadBrowseTemplates(context, category);
                        
                        // Reload contexts in case some context is now empty
                        templateFunctions.loadTemplateContexts();
                        
                        // Reload categories for current context
                        templateFunctions.loadBrowseCategories(context);
                        
                        alert('Template deleted successfully!');
                    } else {
                        alert('Error deleting template: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(error => {
                    console.error('Error deleting template:', error);
                    alert('Error deleting template');
                });
        };

        window.onContextChange = function(value) {
            console.log('Context changed to:', value);
            if (value) {
                window.loadTemplateCategories()
                    .then(() => {
                        console.log('Categories loaded successfully');
                    })
                    .catch(error => {
                        console.error('Error loading categories:', error);
                    });
            } else {
                document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                document.getElementById('templates-container').innerHTML = '';
            }
        };

        window.onCategoryChange = function(value) {
            console.log('Category changed to:', value);
            if (value) {
                window.loadTemplatesList()
                    .then(() => {
                        console.log('Templates loaded successfully');
                    })
                    .catch(error => {
                        console.error('Error loading templates:', error);
                    });
            } else {
                document.getElementById('templates-container').innerHTML = '';
            }
        };

        window.onBrowseContextChange = function(value) {
            console.log('Browse context changed to:', value);
            const category = document.getElementById('browseCategory').value;
            templateFunctions.loadBrowseTemplates(value, category)
                .then(() => {
                    console.log('Browse templates loaded successfully');
                })
                .catch(error => {
                    console.error('Error loading browse templates:', error);
                });
        };

        window.onBrowseCategoryChange = function(value) {
            console.log('Browse category changed to:', value);
            const context = document.getElementById('browseContext').value;
            templateFunctions.loadBrowseTemplates(context, value)
                .then(() => {
                    console.log('Browse templates loaded successfully');
                })
                .catch(error => {
                    console.error('Error loading browse templates:', error);
                });
        };

        window.hideTemplateModal = function() {
            console.log('Hiding template modal...');
            // Get modal element
            const modal = $('#templateModal');
            
            // Hide modal
            modal.removeClass('show');
            modal.css('display', 'none');
            
            // Remove backdrop and cleanup
            $('.modal-backdrop').remove();
            $('body').removeClass('modal-open');
            
            // Remove any alert dialogs that might be open
            $('.alert').remove();
            
            // Clear form
            document.getElementById('templateForm').reset();
            
            // Reset filter dropdowns first
            document.getElementById('filterContext').value = '';
            document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
            
            // Clear templates container
            document.getElementById('templates-container').innerHTML = '';
            
            // Refresh dropdowns after modal close
            templateFunctions.loadTemplateContexts().then(() => {
                templateFunctions.loadBrowseCategories('');
            });
            
            // Reset selects immediately
            document.getElementById('browseContext').value = '';
            templateFunctions.loadBrowseCategories('');
            templateFunctions.loadBrowseTemplates('', '');
            
            // Reset create inputs
            const templateContext = document.getElementById('templateContext');
            if (templateContext) templateContext.value = '';
            const templateCategory = document.getElementById('templateCategory');
            if (templateCategory) templateCategory.value = '';
            
            // Clear template list
            document.getElementById('templateList').innerHTML = '<li class="list-group-item text-muted">Select a context and category to view templates</li>';
            
            // Cleanup any lingering styles
            document.body.style.removeProperty('padding-right');
        };

        // Initialize event handlers when document is ready
        $(document).ready(function() {
            console.log('Initializing template modal handlers...');
            
            // Handle close button click
            $(document).on('click', '#templateModal .close', function() {
                window.hideTemplateModal();
            });
            
            // Handle cancel button click
            $(document).on('click', '#templateModal .btn-secondary', function() {
                window.hideTemplateModal();
            });
            
            // Remove any existing backdrops
            $('.modal-backdrop').remove();
            
            // Prevent clicks inside modal from bubbling up
            $(document).on('click', '#templateModal .modal-content', function(e) {
                e.stopPropagation();
            });
            
            // Close modal when clicking outside
            $(document).on('click', '#templateModal', function(e) {
                if ($(e.target).is('#templateModal')) {
                    window.hideTemplateModal();
                }
            });
            
            // Handle escape key
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $('#templateModal').hasClass('show')) {
                    window.hideTemplateModal();
                }
            });
            
            // Handle modal hidden event
            $('#templateModal').on('hidden.bs.modal', function() {
                // Reset filter dropdowns
                document.getElementById('filterContext').value = '';
                document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                // Clear templates container
                document.getElementById('templates-container').innerHTML = '';
                // Refresh dropdowns
                templateFunctions.loadTemplateContexts().then(() => {
                    templateFunctions.loadBrowseCategories('');
                });
                // Reset selects immediately
                document.getElementById('browseContext').value = '';
                templateFunctions.loadBrowseCategories('');
                templateFunctions.loadBrowseTemplates('', '');
                // Reset create inputs
                const templateContext = document.getElementById('templateContext');
                if (templateContext) templateContext.value = '';
                const templateCategory = document.getElementById('templateCategory');
                if (templateCategory) templateCategory.value = '';
                // Clear template list
                document.getElementById('templateList').innerHTML = '<li class="list-group-item text-muted">Select a context and category to view templates</li>';
            });
        });
    </script>
    <script>
        // Template Management Functions
        // Load categories for selected context
        function loadTemplateCategories() {
            const context = document.getElementById('filterContext').value;
            console.log('Loading categories for context:', context);
            
            if (!context) {
                document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                document.getElementById('templates-container').innerHTML = '';
                return;
            }

            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            fetch(`../../forms/soap/get_template_data.php?csrf_token_form=${encodeURIComponent(csrfToken)}&context=${encodeURIComponent(context)}`)
                .then(response => response.json())
                .then(data => {
                    console.log('Categories response:', data); // Debug log
                    if (data.success && data.categories) {
                        const categorySelect = document.getElementById('filterCategory');
                        categorySelect.innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
                        data.categories.forEach(category => {
                            console.log('Adding category:', category); // Debug log
                            categorySelect.innerHTML += `<option value="${category}">${category}</option>`;
                        });
                        console.log('Categories loaded:', data.categories.length);
                    } else {
                        console.warn('No categories found or error:', data);
                        if (data.debug) {
                            console.log('Debug info:', data.debug);
                        }
                    }
                })
                .catch(error => {
                    console.error('Error loading categories:', error);
                    const categorySelect = document.getElementById('filterCategory');
                    categorySelect.innerHTML = '<option value="">Error loading categories</option>';
                });
        }

        // Load templates for selected context and category
        function loadTemplatesList() {
            const context = document.getElementById('filterContext').value;
            const category = document.getElementById('filterCategory').value;
            if (!context || !category) {
                document.getElementById('templates-container').innerHTML = '';
                return;
            }

            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            fetch(`../../forms/soap/get_template_data.php?csrf_token_form=${encodeURIComponent(csrfToken)}&context=${encodeURIComponent(context)}&category=${encodeURIComponent(category)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.templates) {
                        const container = document.getElementById('templates-container');
                        container.innerHTML = '';
                        data.templates.forEach(template => {
                            const item = createDraggableItem('template', template.template_name, template.template_content);
                            container.appendChild(item);
                        });
                        initializeDragAndDrop();
                    }
                })
                .catch(error => console.error('Error loading templates:', error));
        }

        // Global patient data storage
        window.patientData = {
            fname: '',
            lname: '',
            age: '',
            gender: '',
            dob: ''
        };

        // Function to replace template variables with patient data
        function replaceTemplateVariables(text) {
            if (!text) return text;
            
            console.log('Original template text:', text);
            console.log('Patient data:', window.patientData);
            
            let replacedText = text;
            
            // Replace XX with age
            if (window.patientData && window.patientData.age) {
                replacedText = replacedText.replace(/\bXX\b/g, window.patientData.age);
                console.log('Replaced XX with age:', window.patientData.age);
            } else {
                console.warn('Age not available in patient data');
            }
            
            // Replace Pt with patient full name
            if (window.patientData && window.patientData.fname) {
                const fullName = window.patientData.fname + (window.patientData.lname ? ' ' + window.patientData.lname : '');
                replacedText = replacedText.replace(/\bPt\b/g, fullName);
                console.log('Replaced Pt with name:', fullName);
            } else {
                console.warn('Patient name not available in patient data');
            }
            
            console.log('Replaced text:', replacedText);
            return replacedText;
        }

        window.showAddTemplateModal = function() {
            // Remove any existing backdrops
            $('.modal-backdrop').remove();
            
            // Get modal element
            const modal = $('#templateModal');
            
            // Reset modal state
            modal.css('display', 'block');
            modal.addClass('show');
            
            // Add backdrop
            $('body').append('<div class="modal-backdrop fade show"></div>');
            $('body').addClass('modal-open');
            
            // Hide any previous errors
            const errorDiv = document.getElementById('templateError');
            if (errorDiv) {
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';
            }
            
            // Load contexts for both browse and create tabs
            loadTemplateContexts();
            
            // Reset browse dropdowns to default
            document.getElementById('browseContext').value = '';
            document.getElementById('browseCategory').value = '';
            document.getElementById('browseCategory').innerHTML = '<option value="">All Categories</option>';
            
            // Load all categories for the category dropdown
            templateFunctions.loadBrowseCategories('');
            
            // Clear template list
            document.getElementById('templateList').innerHTML = '<li class="list-group-item text-muted">Select a context and category to view templates</li>';
            
            // Clear form fields first
            $('#templateName').val('');
            $('#templateContext').val('');
            $('#templateCategory').val('');
            $('#templateContent').val('');
            
            // Reset form validation state
            $('#templateForm')[0].reset();
            
            // Switch to create tab
            $('#create-tab').tab('show');
            
            // Small delay to ensure tab switch is complete before showing save button
            setTimeout(() => {
                // Show save button
                $('#saveTemplateBtn').removeClass('d-none');
                
                // Focus on template name field
                $('#templateName').focus();
            }, 200);
        };
        
        window.hideTemplateModal = function() {
            // Get modal element
            const modal = $('#templateModal');
            
            // Hide modal
            modal.removeClass('show');
            modal.css('display', 'none');
            
            // Remove backdrop and cleanup
            $('.modal-backdrop').remove();
            $('body').removeClass('modal-open');
            
            // Remove any alert dialogs that might be open
            $('.alert').remove();
            
            // Clear form
            document.getElementById('templateForm').reset();
            
            // Reset filter dropdowns first
            document.getElementById('filterContext').value = '';
            document.getElementById('filterCategory').innerHTML = '<option value="">{{ "Select Category"|xlt }}</option>';
            
            // Clear templates container
            document.getElementById('templates-container').innerHTML = '';
            
            // Refresh dropdowns after modal close
            templateFunctions.loadTemplateContexts().then(() => {
                templateFunctions.loadBrowseCategories('');
            });
            
            // Reset selects immediately
            document.getElementById('browseContext').value = '';
            templateFunctions.loadBrowseCategories('');
            templateFunctions.loadBrowseTemplates('', '');
            
            // Reset create inputs
            const templateContext = document.getElementById('templateContext');
            if (templateContext) templateContext.value = '';
            const templateCategory = document.getElementById('templateCategory');
            if (templateCategory) templateCategory.value = '';
            
            // Clear template list
            document.getElementById('templateList').innerHTML = '<li class="list-group-item text-muted">Select a context and category to view templates</li>';
            
            // Cleanup any lingering styles
            document.body.style.removeProperty('padding-right');
        }

        // Update close button handler
        $(document).ready(function() {
            // Handle close button click
            $(document).on('click', '#templateModal .close', function() {
                hideTemplateModal();
            });
            
            // Handle cancel button click
            $(document).on('click', '#templateModal .btn-secondary', function() {
                hideTemplateModal();
            });

            // Remove any existing backdrops
            $('.modal-backdrop').remove();
            
            // Prevent clicks inside modal from bubbling up
            $(document).on('click', '#templateModal .modal-content', function(e) {
                e.stopPropagation();
            });
            
            // Close modal when clicking outside
            $(document).on('click', '#templateModal', function(e) {
                if ($(e.target).is('#templateModal')) {
                    hideTemplateModal();
                }
            });
            
            // Handle escape key
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $('#templateModal').hasClass('show')) {
                    hideTemplateModal();
                }
            });
        });

        window.saveTemplate = function() {
            console.log('saveTemplate called');
            
            // Hide any previous errors
            const errorDiv = document.getElementById('templateError');
            if (errorDiv) {
                errorDiv.style.display = 'none';
                errorDiv.textContent = '';
            }
            
            const nameField = document.getElementById('templateName');
            if (!nameField) {
                if (errorDiv) {
                    errorDiv.textContent = 'Template form not found. Please open the create template modal first.';
                    errorDiv.style.display = 'block';
                }
                return;
            }
            
            const contextField = document.getElementById('templateContext');
            const categoryField = document.getElementById('templateCategory');
            const contentField = document.getElementById('templateContent');
            
            if (!contextField || !categoryField || !contentField) {
                alert('Template form not loaded properly. Please refresh the page and try again.');
                return;
            }
            
            console.log('Fields found:', {
                nameField: !!nameField,
                contextField: !!contextField,
                categoryField: !!categoryField,
                contentField: !!contentField
            });
            
            const templateData = {
                name: nameField ? nameField.value : '',
                context: contextField ? contextField.value : '',
                category: categoryField ? categoryField.value : '',
                content: contentField ? contentField.value : '',
                csrf_token_form: {{ csrfTokenRaw()|json_encode }}
            };

            console.log('Template data to save:', templateData);

            // Validate required fields
            if (!templateData.name || !templateData.name.trim()) {
                console.error('Name field is empty:', templateData.name);
                if (errorDiv) {
                    errorDiv.textContent = 'Please enter a template name';
                    errorDiv.style.display = 'block';
                }
                return;
            }
            if (!templateData.context || !templateData.context.trim()) {
                console.error('Context field is empty:', templateData.context);
                if (errorDiv) {
                    errorDiv.textContent = 'Please enter a context';
                    errorDiv.style.display = 'block';
                }
                return;
            }
            if (!templateData.category || !templateData.category.trim()) {
                console.error('Category field is empty:', templateData.category);
                if (errorDiv) {
                    errorDiv.textContent = 'Please enter a category';
                    errorDiv.style.display = 'block';
                }
                return;
            }
            if (!templateData.content || !templateData.content.trim()) {
                console.error('Content field is empty:', templateData.content);
                if (errorDiv) {
                    errorDiv.textContent = 'Please enter template content';
                    errorDiv.style.display = 'block';
                }
                return;
            }

            // Show loading state
            const saveButton = document.getElementById('saveTemplateBtn');
            const originalText = saveButton.innerHTML;
            saveButton.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';
            saveButton.disabled = true;

            fetch('../../forms/soap/save_template.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: Object.entries(templateData)
                    .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(value)}`)
                    .join('&')
            })
            .then(response => response.json())
            .then(data => {
                // Reset button state
                saveButton.innerHTML = originalText;
                saveButton.disabled = false;
                
                if (data.success) {
                    // Show success message
                    alert('Template saved successfully!');
                    
                    // Clear form
                    document.getElementById('templateName').value = '';
                    document.getElementById('templateContext').value = '';
                    document.getElementById('templateCategory').value = '';
                    document.getElementById('templateContent').value = '';
                    
                    // Reload contexts and categories to include the new one
                    templateFunctions.loadTemplateContexts().then(() => {
                        // Switch to browse tab to show the new template
                        $('#browse-tab').tab('show');
                        
                        // Reload browse templates
                        const context = document.getElementById('browseContext').value;
                        const category = document.getElementById('browseCategory').value;
                        templateFunctions.loadBrowseTemplates(context, category);
                    });
                } else {
                    alert('Error saving template: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Error saving template:', error);
                saveButton.innerHTML = originalText;
                saveButton.disabled = false;
                alert('Error saving template');
            });
        };
    </script>
