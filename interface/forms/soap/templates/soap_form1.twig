            <!-- SOAP Form Content -->
            <div class="soap-content">
                <h2>{{'SOAP'|xlt}}</h2>
                <form name="soap" method="post" action="{{ FORM_ACTION | attr }}/interface/forms/soap/save.php" onsubmit="return top.restoreSession()">
                    <input type="hidden" name="csrf_token_form" value="{{ csrfTokenRaw()|attr }}" />
                    <fieldset>
                        <legend>{{ 'Subjective' | xlt }}</legend>
                        <div class="container">
                            <div class="drop-zone" data-target="subjective">
                                {{ 'Drop clinical data here or click to add content'|xlt }}
                            </div>
                            <div class="form-group" >
                                <textarea name="subjective" id="subjective" class="form-control soap-textarea" cols="60" rows="6" onkeyup="top.isSoapEdit = true;">{{ data.get_subjective()|text }}</textarea>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend>{{ 'Objective' | xlt }}</legend>
                        <div class="container">
                            <div class="drop-zone" data-target="objective">
                                {{ 'Drop clinical data here or click to add content'|xlt }}
                            </div>
                            <div class="form-group">
                                <textarea name="objective" id="objective" class="form-control soap-textarea" cols="60" rows="6" onkeyup="top.isSoapEdit = true;">{{ data.get_objective()|text }}</textarea>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend>{{ 'Assessment'|xlt }}</legend>
                        <div class="container">
                            <div class="drop-zone" data-target="assessment">
                                {{ 'Drop clinical data here or click to add content'|xlt }}
                            </div>
                            <div class="form-group">
                                <textarea name="assessment" id="assessment" class="form-control soap-textarea" cols="60" rows="6" onkeyup="top.isSoapEdit = true;">{{ data.get_assessment()|text }}</textarea>
                            </div>
                        </div>
                    </fieldset>
                    <fieldset>
                        <legend>{{ 'Plan'|xlt }}</legend>
                        <div class="container">
                            <div class="drop-zone" data-target="plan">
                                {{ 'Drop clinical data here or click to add content'|xlt }}
                            </div>
                            <div class="form-group">
                                <textarea name="plan" id="plan" class="form-control soap-textarea" cols="60" rows="6" onkeyup="top.isSoapEdit = true;">{{ data.get_plan()|text }}</textarea>
                            </div>
                        </div>
                    </fieldset>

                    <div class="form-group">
                        <div class="btn-group" role="group">
                            <button type="submit" class="btn btn-primary btn-save" name="Submit">{{ 'Save'|xlt }}</button>
