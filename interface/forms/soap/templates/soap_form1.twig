        // Template Management Functions
        function initializeTemplateManagement() {
            try {
                const addTemplateBtn = document.getElementById('add-template-btn');
                if (!addTemplateBtn) {
                    console.error('Add template button not found in DOM');
                    return;
                }

                // Add template button click
                addTemplateBtn.addEventListener('click', function() {
                    const contextSelect = document.getElementById('template-context-select');
                    const categorySelect = document.getElementById('template-category-select');

                    // Pre-populate with current selections if any
                    let preselectedContext = '';
                    let preselectedCategory = '';

                    if (contextSelect && contextSelect.value) {
                        preselectedContext = contextSelect.value;
                    }
                    if (categorySelect && categorySelect.value) {
                        preselectedCategory = categorySelect.value;
                    }

                    // Open template modal
                    openTemplateModal(preselectedContext, preselectedCategory);
                });

                console.log('Template management initialized successfully');
            } catch (error) {
                console.error('Error initializing template management:', error);
            }
        }

        // Handle tab switching
        function switchTab(tabId) {
            try {
                // Hide all tab panes
                document.querySelectorAll('.tab-pane').forEach(function(pane) {
                    pane.classList.remove('show', 'active');
                });
                
                // Deactivate all tabs
                document.querySelectorAll('.nav-link').forEach(function(tab) {
                    tab.classList.remove('active');
                });
                
                // Show selected tab pane
                const selectedPane = document.getElementById(tabId);
                if (selectedPane) {
                    selectedPane.classList.add('show', 'active');
                }
                
                // Activate selected tab
                const selectedTab = document.querySelector('[href="#' + tabId + '"]');
                if (selectedTab) {
                    selectedTab.classList.add('active');
                }

                // Update footer buttons based on active tab
                const saveButton = document.getElementById('save-template-btn');
                if (saveButton) {
                    saveButton.style.display = tabId === 'create-tab' ? 'block' : 'none';
                }
            } catch (error) {
                console.error('Error switching tabs:', error);
            }
        }

        function openTemplateModal(preselectedContext, preselectedCategory) {
            preselectedContext = preselectedContext || '';
            preselectedCategory = preselectedCategory || '';
            console.log('Opening template modal', { preselectedContext, preselectedCategory });
            
            const modal = document.getElementById('templateModal');
            if (!modal) {
                console.error('Template modal element not found!');
                return;
            }
            
            const backdrop = document.getElementById('modalBackdrop');
            if (!backdrop) {
                console.error('Modal backdrop element not found!');
                return;
            }
            
            const contextInput = document.getElementById('new-context');
            const categoryInput = document.getElementById('new-category');

            // Initialize tab handlers
            document.querySelectorAll('.nav-link').forEach(tab => {
                tab.addEventListener('click', (e) => {
                    e.preventDefault();
                    const tabId = e.target.getAttribute('href').substring(1);
                    switchTab(tabId);
                });
            });

            // Set pre-selected values if provided
            if (preselectedContext) {
                contextInput.value = preselectedContext;
            }
            if (preselectedCategory) {
                categoryInput.value = preselectedCategory;
            }

            // Show modal and backdrop
            modal.classList.add('active');
            backdrop.classList.add('active');

            // Focus first empty field
            if (!contextInput.value) {
                contextInput.focus();
            } else if (!categoryInput.value) {
                categoryInput.focus();
            } else {
                document.getElementById('new-template-name').focus();
            }
                        });
                        return;
                    }

                    if (event.data.type === 'TEMPLATE_SAVED') {
                        // Refresh template list if we're viewing the same context/category
                        const contextSelect = document.getElementById('template-context-select');
                        const categorySelect = document.getElementById('template-category-select');

                        if (contextSelect.value === event.data.context && categorySelect.value === event.data.category) {
                            loadTemplateList(event.data.context, event.data.category);
                        }

                        // Update context dropdown if it's a new context
                        if (contextSelect.value !== event.data.context) {
                            const option = document.createElement('option');
                            option.value = event.data.context;
                            option.textContent = event.data.context;
                            contextSelect.appendChild(option);
                        }

                        // Show success message
                        alert('Template saved successfully!');

                        // Remove event listener
                        window.removeEventListener('message', handlePopupMessage);
                    }
                });
            } else {
                alert('Popup blocked! Please allow popups for this site.');
            }
        }
    </script>
    <!-- Template Modal -->
    <div id="templateModal" class="template-modal">
        <div class="template-modal-header">
            <h4><i class="fa fa-plus-circle text-primary"></i> Create Custom Template</h4>
            <button type="button" class="close" onclick="closeTemplateModal()">&times;</button>
        </div>
        <div class="template-modal-content">
            <!-- Navigation tabs -->
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-toggle="tab" href="#create-tab" role="tab">Create Template</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#manage-tab" role="tab">Manage Templates</a>
                </li>
            </ul>

            <!-- Tab content -->
            <div class="tab-content">
                <!-- Create Template Tab -->
                <div class="tab-pane fade show active" id="create-tab" role="tabpanel">
                    <div class="template-modal-body">
                        <div class="alert alert-info">
                            <i class="fa fa-info-circle"></i>
                            Create new templates for your SOAP notes. Select an existing context or create a new one.
                        </div>

                        <form id="template-form">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token_js }}" />
                            
                            <div class="template-form-group">
                                <label for="new-context">Context <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <select class="form-control" id="new-context" name="context" required>
                                        <option value="">Select or type to create new</option>
                                    </select>
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-primary" onclick="toggleContextInput()">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                                <div id="context-suggestions" class="suggestion-badges"></div>
                            </div>

                            <div class="template-form-group">
                                <label for="new-category">Category <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <select class="form-control" id="new-category" name="category" required>
                                        <option value="">Select or type to create new</option>
                                    </select>
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-primary" onclick="toggleCategoryInput()">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
