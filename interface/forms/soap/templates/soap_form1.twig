                                <div class="col">
                                    <select class="form-control" id="filter-context" onchange="filterTemplates()">
                                        <option value="">All Contexts</option>
                                    </select>
                                </div>
                                <div class="col">
                                    <select class="form-control" id="filter-category" onchange="filterTemplates()">
                                        <option value="">All Categories</option>
                                    </select>
