                findingsByDate[date].push(finding);
            });
            Object.keys(findingsByDate).sort((a, b) => new Date(b) - new Date(a)).forEach(date => {
                const group = findingsByDate[date];
                // Remove trailing colon and whitespace from date if present
                let cleanDate = date;
