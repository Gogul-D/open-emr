        function populateVitals(vitals) {
            const container = document.getElementById('vitals-container');
            const loading = document.getElementById('vitals-loading');
            
            if (!container) {
                console.warn('Vitals container not found');
                return;
            }
            
            if (loading) {
                loading.style.display = 'none';
            }
            
            if (vitals.length === 0) {
                container.innerHTML = '<div class="text-muted">{{ "No recent vital signs available"|xlt }}</div>';
                return;
            }
            
            // Group vitals by date/encounter
            const vitalGroups = {};
            vitals.forEach(vital => {
                // Try different date field names that might be used
                const date = vital.date || vital.datetime || vital.created_time || vital.encounter_date || 'Unknown Date';
                if (!vitalGroups[date]) {
                    vitalGroups[date] = [];
                }
                vitalGroups[date].push(vital);
            });
            
            // Debug: Log the vital groups to see what dates we're getting
            console.log('Vital groups:', vitalGroups);
            
            // Create draggable groups for each date
            Object.keys(vitalGroups).sort((a, b) => {
                if (a === 'Unknown Date') return 1;
                if (b === 'Unknown Date') return -1;
                return new Date(b) - new Date(a);
            }).forEach(date => {
                const vitalSet = vitalGroups[date];
                
                // Format the date for display
                let displayDate = date;
                if (date !== 'Unknown Date') {
                    try {
                        // Try to parse and format the date
                        const parsedDate = new Date(date);
                        if (!isNaN(parsedDate.getTime())) {
                            // Format as YYYY-MM-DD HH:MM:SS
                            displayDate = parsedDate.getFullYear() + '-' + 
                                        String(parsedDate.getMonth() + 1).padStart(2, '0') + '-' + 
                                        String(parsedDate.getDate()).padStart(2, '0') + ' ' +
                                        String(parsedDate.getHours()).padStart(2, '0') + ':' + 
                                        String(parsedDate.getMinutes()).padStart(2, '0') + ':' + 
                                        String(parsedDate.getSeconds()).padStart(2, '0');
                        }
                    } catch (e) {
                        console.warn('Date parsing error:', e);
                        displayDate = date; // Use original if parsing fails
                    }
                }
                
                // Create combined content for all vitals from this date
                let combinedContent = `Most recent vitals from: ${displayDate}\n\n`;
                
                vitalSet.forEach(vital => {
                    // Extract the vital name and value from the content
                    let vitalName = vital.header || vital.type || vital.name;
                    let vitalValue = vital.content || vital.value || vital.data;
                    
                    // Clean up numeric values to remove trailing zeros
                    if (typeof vitalValue === 'string') {
                        // Remove trailing zeros from decimal numbers
                        vitalValue = vitalValue.replace(/(\d+)\.0+(\s|$)/g, '$1$2');
                        vitalValue = vitalValue.replace(/(\d+\.\d*?)0+(\s|$)/g, '$1$2');
                    }
                    
                    combinedContent += `${vitalName}:\t${vitalValue}\n`;
                });
                
                // Create a single draggable item for the entire vital set
                const header = `Vital Signs - ${displayDate}`;
                const item = createDraggableItem('vital-set', header, combinedContent.trim());
                
                // Add special styling for vital sets
                item.classList.add('vital-set-item');
                
                container.appendChild(item);
            });
            
            // Initialize drag and drop for new items
            initializeDragAndDrop();
        }

