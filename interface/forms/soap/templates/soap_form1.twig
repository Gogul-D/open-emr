            let header;
            if (eventObj && eventObj.target) {
                header = eventObj.target.closest('.section-header');
            } else {
                // Find the header by looking for the onclick attribute that matches this sectionId
                header = document.querySelector(`[onclick*="toggleSection('${sectionId}')"]`);
                // Alternative: find by searching for the section and getting its previous sibling
                if (!header && section) {
                    const parentSection = section.closest('.clinical-section');
                    if (parentSection) {
                        header = parentSection.querySelector('.section-header');
                    }
                }
            }
            
            if (!header || !section) {
                console.warn(`Could not find header or section for ${sectionId}`);
                return;
            }
            
            const toggle = header.querySelector('.section-toggle');
            const parentSection = header.closest('.clinical-section');
            
