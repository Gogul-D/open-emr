        function loadTemplateList(contextId, categoryId) {
            const listContainer = document.getElementById('template-list-container');
            listContainer.innerHTML = '<div class="loading-message">{{ "Loading templates..."|xlt }}</div>';
            
            const csrfToken = {{ csrfTokenRaw()|json_encode }};
            
            // Use GET method to match the working get_clinical_data.php pattern
            const url = `../../forms/soap/get_templates.php?context=${encodeURIComponent(contextId)}&category=${encodeURIComponent(categoryId)}&csrf_token=${encodeURIComponent(csrfToken)}`;
            
            fetch(url)
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }
                return response.text().then(text => {
                    try {
                        return JSON.parse(text);
                    } catch (e) {
                        console.error('Invalid JSON response:', text);
                        throw new Error('Invalid JSON response from server');
                    }
                });
            })
            .then(data => {
                listContainer.innerHTML = '';
                
                if (Object.keys(data).length === 0) {
                    listContainer.innerHTML = '<div class="text-muted">{{ "No templates found for this category"|xlt }}</div>';
                    return;
                }
                
                // Convert the response to the expected format
                Object.keys(data).forEach(categoryKey => {
                    const template = {
                        id: categoryKey,
                        title: categoryKey,
                        content: data[categoryKey]
                    };
                    const templateItem = createDraggableTemplate(template);
                    listContainer.appendChild(templateItem);
                });
                
                // Initialize drag and drop for new templates
                initializeDragAndDrop();
            })
            .catch(error => {
                console.error('Error loading templates:', error);
                listContainer.innerHTML = `<div class="text-danger">{{ "Error loading templates"|xlt }}: ${error.message}</div>`;
            });
        }
        
        function createDraggableTemplate(template) {
            const item = document.createElement('div');
            item.className = 'draggable-item template-item';
            item.draggable = true;
            item.setAttribute('data-type', 'template');
            item.setAttribute('data-template-id', template.id);
            
            const headerEl = document.createElement('div');
            headerEl.className = 'data-item-header';
            headerEl.textContent = template.title;
            
            // Replace age placeholder in preview content
            let previewContent = template.content.substring(0, 100) + (template.content.length > 100 ? '...' : '');
            if (patientAge && previewContent.includes('XX yr old')) {
                previewContent = previewContent.replace(/XX yr old/g, patientAge + ' yr old');
            }
            
            const contentEl = document.createElement('div');
            contentEl.className = 'data-item-content';
            contentEl.textContent = previewContent;
            
            item.appendChild(headerEl);
            item.appendChild(contentEl);
            
            // Store full content as data attribute for dragging
            item.setAttribute('data-template-content', template.content);
            
            return item;
        }
        
