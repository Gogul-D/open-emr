
<html>
<head>
<title>{{ 'SOAP'|xlt }}</title>
    {{ setupHeader() }}
    <script>
        // Define loadSectionData function
        function loadSectionData(sectionId) {
            // Try multiple sources for patient ID
            let pid = {{ data.get_pid()|default('null')|json_encode }};
            let encounter = {{ encounter|default('null')|json_encode }};
            let csrfToken = {{ csrf_token_form|default('null')|json_encode }};
            
            // Get pid from URL if not available in template
            if (!pid) {
                const urlParams = new URLSearchParams(window.location.search);
                pid = urlParams.get('pid');
            }
            
            // Check hidden input field
            if (!pid) {
                const pidInput = document.querySelector('input[name="pid"]');
                if (pidInput) {
                    pid = pidInput.value;
                }
            }
            
            // Check parent and top frames
            if (!pid) {
                if (typeof parent !== 'undefined' && parent.session && parent.session.pid) {
                    pid = parent.session.pid;
                } else if (typeof top !== 'undefined' && top.session && top.session.pid) {
                    pid = top.session.pid;
                }
            }
            
            if (!pid || pid === null || pid === '') {
                console.error('No patient ID available');
                const loadingEl = document.getElementById(`${sectionId}-loading`);
                if (loadingEl) {
                    loadingEl.innerHTML = '<div class="text-danger">Patient ID not available - cannot load data</div>';
                }
                return;
            }

            console.log('Making API call with PID:', pid, 'and encounter:', encounter);
            
            fetch('../../forms/soap/get_clinical_data.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `pid=${encodeURIComponent(pid)}&encounter=${encodeURIComponent(encounter)}&csrf_token_form=${encodeURIComponent(csrfToken)}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    console.error('Error loading clinical data:', data.error);
                    return;
                }
                
                switch(sectionId) {
                    case 'patient-details':
                        if (data.patient_details) {
                            populatePatientDetails(data.patient_details);
                        }
                        break;
                    case 'allergies':
                        if (data.allergies) {
                            populateAllergies(data.allergies);
                        }
                        break;
                    case 'medications':
                        if (data.medications) {
                            populateMedications(data.medications);
                        }
                        break;
                    case 'forms':
                        if (data.physical_exam) {
                            populatePhysicalExam(data.physical_exam);
                        }
                        if (data.ros) {
                            populateROS(data.ros);
                        }
                        break;
                    case 'vital-signs':
                        if (data.vitals) {
                            populateVitals(data.vitals);
                        }
                        break;
                    case 'problems':
                        if (data.medical_problems) {
                            populateProblems(data.medical_problems);
                        }
                        break;
                    case 'orders-referrals':
                        if (data.forms) {
                            populateOrdersReferralsTab(data.forms);
                        }
                        break;
                    case 'prescriptions':
                        if (data.prescriptions) {
                            populatePrescriptions(data.prescriptions);
                        }
                        break;
                    case 'templates':
                        loadTemplatesSection();
                        break;
                    case 'history':
                        if (data.history) {
                            populateHistory(data.history);
                        }
                        break;
                    default:
                        console.log('No specific loader for section:', sectionId);
                }
            })
            .catch(error => {
                console.error('Error fetching clinical data:', error);
                const loadingEl = document.getElementById(`${sectionId}-loading`);
                if (loadingEl) {
                    loadingEl.innerHTML = '<div class="text-danger">Error loading data</div>';
                }
            });
        }

        // Define toggleSection immediately to ensure it's available
        function toggleSection(sectionId, eventObj = null) {
            try {
                let header, section;
                
                if (eventObj && eventObj.target) {
                    header = eventObj.target.closest('.section-header');
                    section = header ? header.nextElementSibling : null;
                } else {
                    header = document.querySelector('[onclick*="toggleSection(\'' + sectionId + '\')"]');
                    section = document.getElementById(sectionId);
                }

                if (!header || !section) {
                    console.error('Section elements not found:', { sectionId, header, section });
                    return;
                }

                const isActive = section.classList.contains('active');
                section.classList.toggle('active');
                section.style.display = isActive ? 'none' : 'block';
                
                const icon = header.querySelector('.fa');
                if (icon) {
                    icon.classList.toggle('fa-chevron-down');
                    icon.classList.toggle('fa-chevron-right');
                }

                if (!isActive) {
                    loadSectionData(sectionId);
                }
            } catch (error) {
                console.error('Error in toggleSection:', error);
            }
        }
        window.toggleSection = toggleSection;
    </script>
    <style>
