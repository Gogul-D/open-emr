        // Track which sections have been loaded
        const loadedSections = new Set();
        
        // Load data for specific section
        function loadSectionData(sectionId) {
            // Don't reload if already loaded
            if (loadedSections.has(sectionId)) {
                return;
            }
            
            // Try multiple sources for patient ID
            let pid = {{ data.get_pid()|default('null')|json_encode }};
            let encounter = {{ encounter|default('null')|json_encode }};
            const csrfToken = {{ csrfTokenRaw()|json_encode }};
      
            
            // If pid is still not available from form data, try other sources
            if (!pid || pid === null || pid === '') {
                
                
                // Try template variables
                pid = {{ pid|default('null')|json_encode }};
                
                
                // Try to get from parent window session
                if ((!pid || pid === null) && typeof parent !== 'undefined' && parent.session && parent.session.pid) {
                    pid = parent.session.pid;
                   
                }
                // Try to get from top window session
                else if ((!pid || pid === null) && typeof top !== 'undefined' && top.session && top.session.pid) {
                    pid = top.session.pid;
                   
                }
                // Try to get from URL parameters
                else if (!pid || pid === null) {
                    const urlParams = new URLSearchParams(window.location.search);
                    pid = urlParams.get('pid');
                    
                }
                // Try to get from hidden input field
                else if (!pid || pid === null) {
                    const pidInput = document.querySelector('input[name="pid"]');
                    if (pidInput && pidInput.value) {
                        pid = pidInput.value;
                      
                    } else {
                        console.log('❌ No PID found in hidden input field');
                    }
                }
            }
                        
            // If encounter is not available, try alternative sources
            if (!encounter || encounter === null || encounter === '') {
                console.log('⚠️ Encounter is empty, trying alternative sources...');
                if (typeof parent !== 'undefined' && parent.session && parent.session.encounter) {
                    encounter = parent.session.encounter;
                    console.log('✅ Encounter found from parent.session:', encounter);
                }
                else if (typeof top !== 'undefined' && top.session && top.session.encounter) {
                    encounter = top.session.encounter;
                    console.log('✅ Encounter found from top.session:', encounter);
                }
                else {
                    const urlParams = new URLSearchParams(window.location.search);
                    encounter = urlParams.get('encounter');
                    console.log('Encounter from URL parameters:', encounter);
                }
            }
            
            if (!pid || pid === null || pid === '') {
                console.error('❌ No patient ID available from any source');
                console.log('🔍 Debugging info:', {
                    'data.get_pid()': {{ data.get_pid()|default('null')|json_encode }},
                    'pid template var': {{ pid|default('null')|json_encode }},
                    'URL params': new URLSearchParams(window.location.search).get('pid'),
                    'Hidden input': document.querySelector('input[name="pid"]')?.value,
                    'Parent session': typeof parent !== 'undefined' && parent.session ? parent.session.pid : 'not available',
                    'Top session': typeof top !== 'undefined' && top.session ? top.session.pid : 'not available'
                });
                // Hide loading indicators and show error
                document.querySelectorAll('[id$="-loading"]').forEach(loading => {
                    loading.innerHTML = '<div class="text-danger">{{ "Patient ID not available - cannot load clinical data"|xlt }}</div>';
                });
                return;
            }
            
            console.log('🚀 Making API call with PID:', pid, 'and encounter:', encounter);
            
            fetch('../../forms/soap/get_clinical_data.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `pid=${encodeURIComponent(pid)}&encounter=${encodeURIComponent(encounter)}&csrf_token_form=${encodeURIComponent(csrfToken)}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    console.error('Error loading clinical data:', data.error);
                    return;
                }
                
                // Load data for the specific section
                switch(sectionId) {
                    case 'forms':
                        if (data.physical_exam) {
                            populatePhysicalExam(data.physical_exam);
                        }
                        if (data.ros) {
                            populateROS(data.ros);
                        }
                        if (data.eligibility_notes) {
                            if (typeof populateEligibility === 'function') {
                                populateEligibility(data.eligibility_notes);
                            } else {
                                document.getElementById('eligibility-loading').style.display = 'none';
                                document.getElementById('eligibility-container').innerHTML = '<div class="text-muted">No eligibility notes available</div>';
                            }
                        }
                        if (data.nurses_notes) {
                            if (typeof populateNurses === 'function') {
                                populateNurses(data.nurses_notes);
                            } else {
                                document.getElementById('nurses-loading').style.display = 'none';
                                document.getElementById('nurses-container').innerHTML = '<div class="text-muted">No nurses notes available</div>';
                            }
                        }
                        loadedSections.add(sectionId);
                        break;
                    case 'patient-details':
                        if (data.patient_details) {
                            populatePatientDetails(data.patient_details);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'vital-signs':
                        if (data.vitals) {
                            populateVitals(data.vitals);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'orders-referrals':
                        if (data.forms) {
                            populateOrdersReferralsTab(data.forms);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'allergies':
                        if (data.allergies) {
                            populateAllergies(data.allergies);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'physical-exam':
                        if (data.physical_exam) {
                            populatePhysicalExam(data.physical_exam);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'labs':
                        if (data.labs) {
                            populateLabs(data.labs);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'medications':
                        if (data.medications) {
                            populateMedications(data.medications);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'prescriptions':
                        if (data.prescriptions) {
                            populatePrescriptions(data.prescriptions);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'problems':
                        if (data.medical_problems) {
                            populateProblems(data.medical_problems);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'ros':
                        if (data.ros) {
                            populateROS(data.ros);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'history':
                        if (data.history) {
                            populateHistory(data.history);
                            loadedSections.add(sectionId);
                        }
                        break;
                    case 'templates':
                        loadTemplatesSection();
                        loadedSections.add(sectionId);
                        break;
                }
            })
            .catch(error => {
                console.error('Error fetching clinical data:', error);
                
                // Hide loading indicators on error
                const loadingDiv = document.querySelector(`#${sectionId} [id$="-loading"]`);
                if (loadingDiv) {
                    loadingDiv.style.display = 'none';
                }
            });
        }

        // Drag and Drop functionality
        function initializeDragAndDrop() {
            // Make all draggable items draggable
            document.querySelectorAll('.draggable-item').forEach(item => {
                item.addEventListener('dragstart', handleDragStart);
                item.addEventListener('dragend', handleDragEnd);
            });

            // Set up drop zones
            document.querySelectorAll('.drop-zone').forEach(zone => {
                zone.addEventListener('dragover', handleDragOver);
                zone.addEventListener('dragenter', handleDragEnter);
                zone.addEventListener('dragleave', handleDragLeave);
                zone.addEventListener('drop', handleDrop);
                zone.addEventListener('click', handleDropZoneClick);
            });

            // Set up textarea drop functionality
            document.querySelectorAll('.soap-textarea').forEach(textarea => {
                textarea.addEventListener('dragover', handleTextareaDragOver);
                textarea.addEventListener('drop', handleTextareaDrop);
            });
        }

        function handleDragStart(e) {
            draggedElement = this;
            isDraggedFromPanel = this.closest('.clinical-sidebar') !== null;
            this.classList.add('dragging');
            
            // Get the type of item being dragged
            const itemType = this.getAttribute('data-type');
            
            let fullText = '';
            
            if (itemType === 'vital-set') {
                // For vital sets, use the full formatted content
                const content = this.querySelector('.data-item-content').textContent;
                fullText = content;
            } else if (itemType === 'order-referral') {
                // For orders and referrals, use the header and format content on new lines
                const header = this.querySelector('.data-item-header').textContent;
                const content = this.querySelector('.data-item-content').textContent;
                fullText = header + '\n' + content;
            } else if (itemType === 'allergy') {
                // For allergies, use the full text content as is
                fullText = this.textContent;
            } else if (itemType === 'medication' || itemType === 'problem') {
                // For medications, use only the header (name) to avoid duplication
                if (itemType === 'medication') {
                    fullText = this.querySelector('.data-item-header').textContent;
                } else if (itemType === 'problem') {
                    // For problems (diagnoses), use both header (date) and content (diagnosis details)
                    const header = this.querySelector('.data-item-header').textContent;
                    const content = this.querySelector('.data-item-content').textContent;
                    fullText = header + ': ' + content;
                }
            } else if (itemType === 'template') {
                // For templates, use the full template content and replace placeholders
                fullText = this.getAttribute('data-template-content') || this.textContent;
                
                // Replace age placeholder with actual patient age
                if (patientAge && fullText.includes('XX yr old')) {
                    fullText = fullText.replace(/XX yr old/g, patientAge + ' yr old');
                }
            } else if (itemType === 'patient_detail') {
                // For patient details, drag only the value of the item being dragged (span's own text)
                fullText = this.textContent.trim();
            } else if (itemType === 'physical-group' || itemType === 'ros-group') {
                // For Physical Exam and Review of Systems, use header and content separated by a newline, no extra colon
                const header = this.querySelector('.data-item-header').textContent;
                const content = this.querySelector('.data-item-content').textContent;
                fullText = header + '\n' + content;
            } else {
                // For other items, use the standard format
                const header = this.querySelector('.data-item-header').textContent;
                const content = this.querySelector('.data-item-content').textContent;
                fullText = header + ': ' + content;
            }
            
            e.dataTransfer.setData('text/plain', fullText);
            e.dataTransfer.effectAllowed = 'copy';
        }

        
        function handleDragEnd(e) {
            this.classList.remove('dragging');
            draggedElement = null;
            isDraggedFromPanel = false;
        }

        function handleDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'copy';
        }

        function handleDragEnter(e) {
            e.preventDefault();
            this.classList.add('drag-over');
        }

        function handleDragLeave(e) {
            if (!this.contains(e.relatedTarget)) {
                this.classList.remove('drag-over');
            }
        }

        function handleDrop(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            
            const droppedText = e.dataTransfer.getData('text/plain');
            const targetTextarea = this.nextElementSibling.querySelector('textarea');
            if (targetTextarea && droppedText) {
                // Mark the dragged item as used
                if (draggedElement && draggedElement.getAttribute('data-item-id')) {
                    const itemId = draggedElement.getAttribute('data-item-id');
                    usedItems.add(itemId);
                    draggedElement.classList.add('used');
                }
                
                // If this is a patient_detail, move cursor to end before inserting
                if (window.draggedElement && window.draggedElement.getAttribute && window.draggedElement.getAttribute('data-type') === 'patient_detail') {
                    targetTextarea.focus();
                    targetTextarea.setSelectionRange(targetTextarea.value.length, targetTextarea.value.length);
                }
                appendToTextarea(targetTextarea, droppedText);
                top.isSoapEdit = true;
            }
        }

        function handleDropZoneClick(e) {
            const targetTextarea = this.nextElementSibling.querySelector('textarea');
            if (targetTextarea) {
                targetTextarea.focus();
            }
        }

        function handleTextareaDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'copy';
            
            // Show insertion point
            const rect = this.getBoundingClientRect();
            const y = e.clientY - rect.top;
            const lineHeight = parseInt(window.getComputedStyle(this).lineHeight);
            const lines = this.value.split('\n');
            const insertLine = Math.min(Math.floor(y / lineHeight), lines.length);
            
            // Visual feedback could be added here
        }

        function handleTextareaDrop(e) {
            e.preventDefault();
            const droppedText = e.dataTransfer.getData('text/plain');
            
            if (droppedText) {
                // Replace age placeholder with actual patient age
                let processedText = droppedText;
                if (patientAge && processedText.includes('XX yr old')) {
                    processedText = processedText.replace(/XX yr old/g, patientAge + ' yr old');
                }
                
                // Mark the dragged item as used
                if (draggedElement && draggedElement.getAttribute('data-item-id')) {
                    const itemId = draggedElement.getAttribute('data-item-id');
                    usedItems.add(itemId);
                    draggedElement.classList.add('used');
                }
                
                // Check for duplicates before inserting
                const currentValue = this.value;
                const normalizedText = processedText.trim().toLowerCase();
                const normalizedCurrentValue = currentValue.toLowerCase();
                const existingLines = currentValue.split('\n').map(line => line.trim().toLowerCase());
                if (existingLines.includes(normalizedText)) {
                    showDuplicateMessage(this, processedText);
                    return;
                }
                if (normalizedCurrentValue.includes(normalizedText) && normalizedText.length > 10) {
                    showDuplicateMessage(this, processedText, true);
                    return;
                }
                // If this is a patient_detail, always append to the last line with a space
                if (window.draggedElement && window.draggedElement.getAttribute && window.draggedElement.getAttribute('data-type') === 'patient_detail') {
                    // Insert at cursor position, never add a newline, only a space if needed
                    const cursorPos = this.selectionStart;
                    let textBefore = this.value.substring(0, cursorPos).replace(/[\n\r]+/g, ' ');
                    let textAfter = this.value.substring(cursorPos).replace(/[\n\r]+/g, ' ');
                    if (textBefore.length > 0 && !textBefore.endsWith(' ')) {
                        textBefore += ' ';
                    }
                    let insertText = processedText.trim();
                    // Avoid double spaces
                    if (textAfter.length > 0 && !insertText.endsWith(' ') && !textAfter.startsWith(' ')) {
                        insertText += ' ';
                    }
                    this.value = textBefore + insertText + textAfter;
                    // Move cursor to after inserted text
                    const newCursorPos = (textBefore + insertText).length;
                    this.setSelectionRange(newCursorPos, newCursorPos);
                    this.focus();
                    top.isSoapEdit = true;
                    return;
                }
                // Default: Insert at cursor with newlines for other types
                const cursorPos = this.selectionStart;
                const textBefore = this.value.substring(0, cursorPos);
                const textAfter = this.value.substring(cursorPos);
                const newText = textBefore + (textBefore && !textBefore.endsWith('\n') ? '\n' : '') + 
                               processedText + 
                               (textAfter && !textAfter.startsWith('\n') ? '\n' : '') + textAfter;
                this.value = newText;
                top.isSoapEdit = true;
                const newCursorPos = cursorPos + processedText.length + 
                                   (textBefore && !textBefore.endsWith('\n') ? 1 : 0) +
                                   (textAfter && !textAfter.startsWith('\n') ? 1 : 0);
                this.setSelectionRange(newCursorPos, newCursorPos);
                this.focus();
            }
        }

        function appendToTextarea(textarea, text) {
            // Replace age placeholder with actual patient age
            if (patientAge && text.includes('XX yr old')) {
                text = text.replace(/XX yr old/g, patientAge + ' yr old');
            }
            
            const currentValue = textarea.value;
            // Check for duplicates - normalize both texts for comparison
            const normalizedText = text.trim().toLowerCase();
            const normalizedCurrentValue = currentValue.toLowerCase();
            const existingLines = currentValue.split('\n').map(line => line.trim().toLowerCase());
            if (existingLines.includes(normalizedText)) {
                showDuplicateMessage(textarea, text);
                return;
            }
            if (normalizedCurrentValue.includes(normalizedText) && normalizedText.length > 10) {
                showDuplicateMessage(textarea, text, true);
                return;
            }
            // Determine if this is a patient_detail drag
            let isPatientDetail = false;
            if (window.draggedElement && window.draggedElement.getAttribute && window.draggedElement.getAttribute('data-type') === 'patient_detail') {
                isPatientDetail = true;
            }
            const cursorPos = textarea.selectionStart;
            const textBefore = textarea.value.substring(0, cursorPos);
            const textAfter = textarea.value.substring(cursorPos);
            let insertText;
            if (isPatientDetail) {
                // Inline insert for patient_detail, always append with a space if needed
                let before = textBefore;
                // Remove trailing newline from before if present
                if (before.endsWith('\n')) {
                    before = before.replace(/\n+$/, '');
                }
                // Add a space if not at start or after a space
                if (before.length > 0 && !before.endsWith(' ')) {
                    before += ' ';
                }
                insertText = text;
                textarea.value = before + insertText + textAfter;
                const newCursorPos = (before + insertText).length;
                textarea.setSelectionRange(newCursorPos, newCursorPos);
            } else {
                // Always insert with newlines for other types
                insertText = (textBefore && !textBefore.endsWith('\n') ? '\n' : '') + text + (textAfter && !textAfter.startsWith('\n') ? '\n' : '');
                textarea.value = textBefore + insertText + textAfter;
                const newCursorPos = textBefore.length + insertText.length;
                textarea.setSelectionRange(newCursorPos, newCursorPos);
            }
            textarea.focus();
            textarea.scrollTop = textarea.scrollHeight;
        }
        
        // Function to reset used items (can be called to allow reusing items)
        function resetUsedItems() {
            usedItems.clear();
            document.querySelectorAll('.draggable-item.used').forEach(item => {
                item.classList.remove('used');
            });
        }
        
        // Make resetUsedItems available globally if needed
        window.resetUsedItems = resetUsedItems;

        // Keyboard shortcuts
        function setupKeyboardShortcuts() {
            document.addEventListener('keydown', function(e) {
                // Ctrl/Cmd + Shift + S for Subjective
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'S') {
                    e.preventDefault();
                    document.getElementById('subjective').focus();
                }
                // Ctrl/Cmd + Shift + O for Objective  
                else if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'O') {
