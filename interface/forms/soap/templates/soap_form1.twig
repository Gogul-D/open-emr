            </div>

            <div class="template-modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeTemplateModal()">
                    <i class="fa fa-times"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" id="save-template-btn" onclick="saveTemplate()">
                    <i class="fa fa-save"></i> Save Template
                </button>
            </div>
        </div>
    </div>
    <div id="modalBackdrop" class="modal-backdrop"></div>

    <script>
        function openTemplateModal(preselectedContext = '', preselectedCategory = '') {
            document.getElementById('templateModal').classList.add('active');
            document.getElementById('modalBackdrop').classList.add('active');
            
            if (preselectedContext) {
                document.getElementById('new-context').value = preselectedContext;
            }
            if (preselectedCategory) {
                document.getElementById('new-category').value = preselectedCategory;
            }
        }

        function closeTemplateModal() {
            document.getElementById('templateModal').classList.remove('active');
            document.getElementById('modalBackdrop').classList.remove('active');
            document.getElementById('template-form').reset();
        }

        function saveTemplate() {
            const form = document.getElementById('template-form');
            const formData = new FormData(form);
            formData.append('action', 'save_template');

            // Validate form
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            // Disable save button and show loading state
            const saveBtn = document.querySelector('.template-modal-footer .btn-primary');
            const originalText = saveBtn.innerHTML;
            saveBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';
            saveBtn.disabled = true;

            // Send request
            fetch('../../forms/soap/manage_templates.php', {
                method: 'POST',
                body: formData
            })
            .then(async response => {
                const data = await response.json();
                
                if (!response.ok) {
                    throw new Error(data.error || `Server error: ${response.status}`);
                }
                
                if (!data.success) {
                    throw new Error(data.error || 'Operation was not successful');
                }
                
                // Update template list if we're viewing the same context/category
                const contextSelect = document.getElementById('template-context-select');
                const categorySelect = document.getElementById('template-category-select');
                
                if (contextSelect.value === formData.get('context') && 
                    categorySelect.value === formData.get('category')) {
                    loadTemplateList(formData.get('context'), formData.get('category'));
                }

                // Update context dropdown if it's a new context
                if (contextSelect.value !== formData.get('context')) {
                    const option = document.createElement('option');
                    option.value = formData.get('context');
                    option.textContent = formData.get('context');
                    contextSelect.appendChild(option);
                }

                alert('Template saved successfully!');
                closeTemplateModal();
            })
            .catch(error => {
                console.error('Error:', error);
                alert(error.message || 'An unexpected error occurred');
            })
            .finally(() => {
                saveBtn.innerHTML = originalText;
                saveBtn.disabled = false;
            });
        }
    </script>
