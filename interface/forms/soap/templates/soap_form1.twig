            if (loading) {
                loading.style.display = 'none';
            }
            container.innerHTML = '';
            console.log('Eligibility notes received:', notes);
            if (!notes || notes.length === 0) {
                container.innerHTML = '<div class="text-muted">No eligibility notes available</div>';
                return;
            }
            notes.forEach(note => {
                // Format content: each field on its own line
                let formattedContent = '';
                if (note.content && typeof note.content === 'string') {
                    formattedContent = note.content; // keep as plain text, do not convert to <br>
                } else {
                    formattedContent = note.content || '';
                }
                const item = createDraggableItem('eligibility', note.header || 'Eligibility Note', formattedContent);
