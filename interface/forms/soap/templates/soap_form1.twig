                    const headerRegex = new RegExp('^\\s*' + escapedHeader + '\\s*[:\\-–—]?\\s*', 'i');
                    details = details.replace(headerRegex, '').trim();
                } catch (e) {
                    console.warn('Prescription header stripping failed', e);
                }

                const contentToShow = details || prescription.content || '';

                // Combine header and content into a single line for display and drag
                const combinedLine = contentToShow ? (headerText + ' - ' + contentToShow) : headerText;
                const item = createDraggableItem(prescription.type, combinedLine, '');
                container.appendChild(item);
            });

            // Initialize drag and drop for new items
            initializeDragAndDrop();
        }
        
